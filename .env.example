# Example environment variables for local development
# Copy this file to `.env` and fill in real values (do NOT commit `.env`).

LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
# Alternatively set LLM_MODEL_NAME if your environment expects that name
LLM_MODEL_NAME=

# Provider-specific API keys (placeholders)
LLM_API_KEY_OPENAI=sk-REPLACE_ME
LLM_API_KEY_OPENROUTER=sk-or-REPLACE_ME
LLM_API_KEY_LOCAL=

# Optional base URLs (override if using custom endpoints)
LLM_BASE_URL_OPENAI=https://api.openai.com/v1
LLM_BASE_URL_LOCAL=http://localhost:1234/v1

# Hugging Face API key (optional)
HUGGING_FACE_API_KEY=hf-REPLACE_ME

# Output path override (optional)
OUTPUT_BASE_PATH=./output
